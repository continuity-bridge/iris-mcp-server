# Iris MCP Server - Environment Variables

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=https://iris.continuitybridge.io/oauth/callback

# Server Configuration
PORT=3000
MCP_SERVER_NAME=iris-gateway
MCP_SERVER_VERSION=0.1.0

# Database (for token storage - use PostgreSQL or SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/iris
# Or for development with SQLite:
# DATABASE_URL=sqlite:./iris.db

# Encryption key for token storage (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your_session_secret_here

# Environment
NODE_ENV=development
